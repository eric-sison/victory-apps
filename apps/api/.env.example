# Base URL of your app
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=change_me_use_a_super_strong_secret

# Database url
DATABASE_URL=postgres://appuser:changeme_use_a_strong_password@localhost:5432/appdb

# Postgres
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=appdb

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme_use_a_strong_password