# Add allowed origins - comma-separated
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000

# Base URL of your app
BETTER_AUTH_URL=http://localhost:3001/api/auth
BETTER_AUTH_SECRET=change_me_use_a_super_strong_secret

# Database url
DATABASE_URL=postgres://appuser:changeme_use_a_strong_password@localhost:5432/appdb

# SMTP — in dev this points to Mailpit (docker compose up)
# In production, replace with your real SMTP provider credentials
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=dev
SMTP_PASSWORD=dev
SMTP_FROM=noreply@example.com

RESET_PASSWORD_CALLBACK=http://localhost:3000/auth/callback/reset-password