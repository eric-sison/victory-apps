{
  "name": "api",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "predev": "pnpm --filter auth build",
    "dev": "tsx scripts/check-db.ts && tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "openapi:generate": "tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/structured-logger": "^0.1.0",
    "@hono/zod-openapi": "^1.3.0",
    "@scalar/hono-api-reference": "^0.10.16",
    "@workspace/auth": "workspace:*",
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.19",
    "hono-rate-limiter": "^0.5.3",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.1",
    "typescript": "^5.8.3"
  }
}
