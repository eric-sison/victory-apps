# Postgres Credentials
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=appdb

# pgAdmin default user
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme_use_a_strong_password

# SMTP — in dev this points to Mailpit (docker compose up)
# In production, replace with your real SMTP provider credentials
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=dev
SMTP_PASSWORD=dev
SMTP_FROM=noreply@example.com