# =============================================================================
# docker/.env.example
#
# Single env file for the Docker deployment. Copy to docker/.env and fill in
# real values. apps/api has been merged into apps/admin — there is no separate
# api service; all vars now feed into the admin container.
# =============================================================================

# PostgreSQL
POSTGRES_USER=appuser
POSTGRES_PASSWORD=use_a_strong_password
POSTGRES_DB=appdb
DATABASE_URL=postgresql://appuser:use_a_strong_password@postgres:5432/appdb

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=use_a_strong_password

# Better Auth — must be at least 32 characters
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_secret_here_min_32_characters
# The admin app serves the API at /api/auth — port 3000, not 3001
BETTER_AUTH_URL=http://localhost:3000/api/auth

# CORS — comma-separated list of origins allowed to call the embedded API
ALLOWED_ORIGINS=http://localhost:3000

# Default admin user — created automatically on first deploy
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=use_a_strong_password
DEFAULT_ADMIN_NAME=Super Admin

# Frontend — base URL for password reset links generated by Better Auth
RESET_PASSWORD_CALLBACK=https://yourdomain.com/auth/callback/reset-password

# SMTP — replace with your real provider credentials in production
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@yourdomain.com
