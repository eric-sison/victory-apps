{
  "name": "victory-apps",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "deploy:up": "./scripts/deploy.sh",
    "deploy:clean": "./scripts/deploy.sh --no-cache",
    "deploy:build": "./scripts/deploy.sh --build-only",
    "deploy:build:clean": "./scripts/deploy.sh --build-only --no-cache",
    "deploy:start": "./scripts/deploy.sh --skip-build",
    "deploy:down": "./scripts/cleanup.sh",
    "deploy:down:volumes": "./scripts/cleanup.sh --volumes",
    "deploy:down:images": "./scripts/cleanup.sh --images",
    "deploy:down:all": "./scripts/cleanup.sh --all",
    "db:auth:migrate": "./scripts/auth-migrate.sh",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.14",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "packageExtensions": {
      "better-auth": {
        "peerDependenciesMeta": {
          "next": {
            "optional": true
          },
          "react": {
            "optional": true
          },
          "react-dom": {
            "optional": true
          },
          "@tanstack/react-start": {
            "optional": true
          },
          "srvx": {
            "optional": true
          },
          "crossws": {
            "optional": true
          }
        }
      }
    },
    "overrides": {
      "glob": "^10",
      "rimraf": "^5",
      "inflight": "npm:lru-cache@^10",
      "esbuild": "0.27.7"
    },
    "supportedArchitectures": {
      "os": [
        "current",
        "linux"
      ],
      "cpu": [
        "current",
        "arm64",
        "x64"
      ]
    }
  }
}
