{
  "name": "victory-apps",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "deploy:up": "./scripts/deploy.sh",
    "deploy:clean": "./scripts/deploy.sh --no-cache",
    "deploy:build": "./scripts/deploy.sh --build-only",
    "deploy:build:clean": "./scripts/deploy.sh --build-only --no-cache",
    "deploy:start": "./scripts/deploy.sh --skip-build",
    "deploy:down": "./scripts/cleanup.sh",
    "deploy:down:volumes": "./scripts/cleanup.sh --volumes",
    "deploy:down:images": "./scripts/cleanup.sh --images",
    "deploy:down:all": "./scripts/cleanup.sh --all",
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:db:init": "docker compose up -d && pnpm --filter admin db:migrate && pnpm --filter admin db:seed",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.4",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20"
  }
}
