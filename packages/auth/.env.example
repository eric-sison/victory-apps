# Database connection
DATABASE_URL=postgres://appuser:password@localhost:5432/appdb

BETTER_AUTH_URL=http://localhost:3001/api/auth # Where the backend API is running
BETTER_AUTH_SECRET=change_me_use_a_super_strong_secret

DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=supersssecurepassword
DEFAULT_ADMIN_NAMEs=Super Admin

# SMTP — in dev this points to Mailpit (docker compose up)
# In production, replace with your real SMTP provider credentials
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=dev
SMTP_PASSWORD=dev
SMTP_FROM=noreply@example.com