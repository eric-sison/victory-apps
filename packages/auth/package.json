{
  "name": "@workspace/auth",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "files": [
    "dist",
    "src",
    "drizzle.config.ts"
  ],
  "exports": {
    "./server": {
      "types": "./src/lib/auth.ts",
      "default": "./dist/lib/auth.js"
    },
    "./client": {
      "types": "./src/lib/auth-client.ts",
      "default": "./dist/lib/auth-client.js"
    },
    "./schema": {
      "types": "./src/auth-schema.ts",
      "default": "./dist/auth-schema.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:admin": "tsx src/seed-admin.ts"
  },
  "dependencies": {
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.1",
    "typescript": "^5.9.3"
  }
}
